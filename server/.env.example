NODE_ENV=development
PORT=4000

# Laragon's usual local MySQL defaults. Add DB_PASSWORD if yours has one.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=athena_research
DB_CONNECTION_LIMIT=10

# Use * for local Expo development. Restrict this before deployment.
CORS_ORIGIN=*

# Ask Athena uses Groq through the server. Never expose this key through an
# EXPO_PUBLIC_ variable or commit a real key to source control.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_TIMEOUT_MS=30000

# Local database accounts are initialized with this password by db:setup.
DEMO_ACCOUNT_PASSWORD=AthenaDemo2026!
